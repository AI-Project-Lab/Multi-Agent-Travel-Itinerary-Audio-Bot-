# ----------------------------------------------------------------------------
# Environment template.
#
# HOW TO USE:
#   1. Make a copy of this file and rename the copy to ".env"
#   2. Paste your real OpenAI API key after the "=" sign (no quotes needed)
#   3. Never commit your real .env file — it is already in .gitignore
# ----------------------------------------------------------------------------

# Required: your OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Optional: which chat model the agents use. gpt-4o-mini is cheap + fast,
# which is great for a live class. You can swap to gpt-4o for higher quality.
OPENAI_MODEL=gpt-4o-mini
